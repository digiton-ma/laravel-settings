{
    "name":        "digiton-ma/laravel-settings",
    "description": "This package allows you to persists configs/settings for Laravel projects.",
    "homepage":    "https://github.com/digiton-ma/laravel-settings",
    "keywords":    [
        "digiton-ma", "laravel", "config", "settings", "json", "array", "database", "db"
    ],
    "authors":  [
        {
            "name":     "digiton-ma",
            "email":    "contact@digiton.ma",
            "homepage": "https://github.com/digiton-ma",
            "role":     "Developer"
        }
    ],
    "type":    "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "digiton-ma/support": "^12.0"
    },
    "require-dev": {
        "laravel/framework": "^11.0|^12.0|^13.0",
        "mockery/mockery": "^1.6|^2.0",
        "orchestra/testbench-core": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "predis/predis": "^2.0.2|^3.4"
    },
    "autoload": {
        "psr-4": {
            "Digitonma\\LaravelSettings\\": "src/"
        },
        "files": ["helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Digitonma\\LaravelSettings\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-develop": "11.x-dev"
        },
        "laravel": {
            "providers": [
                "Digitonma\\LaravelSettings\\SettingsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:dox": "phpunit --testdox --colors=always",
        "test:cov": "phpunit --coverage-html coverage"
    },
    "suggest": {
        "illuminate/redis": "This package allows you to persist the settings into a redis server."
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
